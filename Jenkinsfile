                echo 'Cloning repository'
            }
        }

        stage('Build') {
            steps {
                echo 'Building portfolio project'
            }
        }

        stage('Test') {
            steps {
                echo 'Testing project'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying project'
            }
        }

    }
}
